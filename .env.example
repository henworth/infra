# Real AWS: rely on the AWS CLI / SSO chain; only set these to pin specific
# accounts/regions:
# CDK_DEFAULT_ACCOUNT=123456789012
# CDK_DEFAULT_REGION=us-east-1

# Ministack (local AWS emulator), used by `bash scripts/cdklocal-deploy.sh`
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
CDK_DEFAULT_ACCOUNT=000000000000
CDK_DEFAULT_REGION=us-east-1

# Used by scripts/reconcile.py to look up the other service repo's branches.
# GITHUB_TOKEN is supplied by GitHub Actions in CI; only needed locally.
GITHUB_ORG=your-org
# GITHUB_TOKEN=ghp_xxx
